generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        Int      @id @default(autoincrement())
  company   String
  contact   String
  email     String   @unique
  phone     String?
  sector    String?
  services  String[]
  status    String   @default("actif")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("clients")
}